<Window x:Class="SiadFrotaDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="SIAD • Gestão de Frota"
        Width="1180"
        Height="860"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- header -->
            <RowDefinition Height="Auto"/>
            <!-- credenciais -->
            <RowDefinition Height="*"/>
            <!-- operações -->
            <RowDefinition Height="6"/>
            <!-- splitter -->
            <RowDefinition Height="130"/>
            <!-- log -->
            <RowDefinition Height="Auto"/>
            <!-- status -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <materialDesign:ColorZone Grid.Row="0" Mode="PrimaryMid" Padding="18">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="SIAD • Gestão de Frota" FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="Consulta e Lançamento • WPF (.NET 8)"
                               Opacity="0.85"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="16,0,0,0">
                    <Button x:Name="BtnCancel"
                            Content="Cancelar"
                            Padding="14,8"
                            MinHeight="40"
                            VerticalContentAlignment="Center"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            IsEnabled="False"
                            Click="BtnCancel_Click"/>
                </StackPanel>
            </DockPanel>
        </materialDesign:ColorZone>

        <!-- CREDENCIAIS (horizontal) -->
        <materialDesign:Card Grid.Row="1" Margin="20,16,20,12" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TxtUsuario"
                         Grid.Column="0"
                         materialDesign:HintAssist.Hint="Usuário"
                         Margin="0,22,12,0"/>

                <PasswordBox x:Name="TxtSenha"
                             Grid.Column="1"
                             materialDesign:HintAssist.Hint="Senha"
                             Margin="0,22,12,0" Password=""/>

                <ComboBox x:Name="CmbUnidade"
                         Grid.Column="1"
                         DisplayMemberPath="Display"
                         SelectedValuePath="Codigo"
                         materialDesign:HintAssist.Hint="Unidade (unProcessadora)"
                         Margin="329,22,12,0" Grid.ColumnSpan="2" VerticalAlignment="Top"/>

                <Button Grid.Column="3"
                        Content="Limpar campos"
                        Padding="14,8"
                        MinHeight="44"
                        VerticalContentAlignment="Center"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Click="BtnClear_Click"/>
            </Grid>
        </materialDesign:Card>

        <!-- OPERAÇÕES (toda largura) -->
        <materialDesign:Card Grid.Row="2" Margin="20,0,20,16" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Operações" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <TabControl Grid.Row="1" x:Name="Tabs">

                    <!-- ===================== CONSULTA ===================== -->
                    <TabItem Header="Consulta">
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Tipo de consulta" FontWeight="SemiBold"/>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
                                <RadioButton x:Name="RbConsultaIndividual"
                                             Content="Viatura específica"
                                             IsChecked="True"
                                             Margin="0,0,14,0"
                                             Checked="RbConsultaTipo_Checked"/>
                                <RadioButton x:Name="RbConsultaTodas"
                                             Content="Todas as viaturas"
                                             Checked="RbConsultaTipo_Checked"/>
                            </StackPanel>

                            <Grid Grid.Row="2" Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox x:Name="CmbConsultaViatura"
                                          Grid.Column="0"
                                          DisplayMemberPath="Display"
                                          SelectedValuePath="Placa"
                                          materialDesign:HintAssist.Hint="Viatura (codinome + placa)"
                                          Visibility="Visible"/>

                                <Button Grid.Column="1"
                                        Content="Iniciar consulta"
                                        Margin="12,0,0,0"
                                        Padding="16,10"
                                        MinHeight="44"
                                        VerticalContentAlignment="Center"
                                        Style="{StaticResource MaterialDesignFlatMidBgButton}"
                                        Click="BtnConsulta_Click"/>
                            </Grid>

                            <DataGrid x:Name="GridConsulta"
                                      Grid.Row="3"
                                      Margin="0,14,0,0"
                                      LoadingRow="GridConsulta_LoadingRow"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      materialDesign:DataGridAssist.CellPadding="12,8">

                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Deletar lançamento"
                                             Click="MenuDeleteLancamento_Click"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Codinome" Binding="{Binding Codinome}" Width="Auto"/>
                                    <DataGridTextColumn Header="Placa" Binding="{Binding Placa}" Width="Auto" MinWidth="90"/>
                                    <DataGridTextColumn Header="Hodômetro" Binding="{Binding Hodometro}" Width="Auto" MinWidth="110"/>
                                    <DataGridTextColumn Header="Hora" Binding="{Binding Hora}" Width="Auto" MinWidth="70"/>
                                    <DataGridTextColumn Header="REDS" Binding="{Binding Ocorrencias}" Width="Auto" MinWidth="120"/>
                                    <DataGridTextColumn Header="Condutor" Binding="{Binding Nome}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <!-- ===================== LANÇAMENTO ===================== -->
                    <TabItem Header="Lançamento">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,10,0,0">

                                <ComboBox x:Name="CmbLancViatura"
                                          DisplayMemberPath="Display"
                                          SelectedValuePath="Placa"
                                          materialDesign:HintAssist.Hint="Viatura (codinome + placa)"/>

                                <TextBlock Text="Tipo de operação" FontWeight="SemiBold" Margin="0,14,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <RadioButton x:Name="RbSaida"
                                                 Content="Saída"
                                                 IsChecked="True"
                                                 Margin="0,0,14,0"
                                                 Checked="RbLancTipo_Checked"/>
                                    <RadioButton x:Name="RbRetorno"
                                                 Content="Retorno"
                                                 Checked="RbLancTipo_Checked"/>
                                </StackPanel>

                                <!-- Saída -->
                                <StackPanel x:Name="PanelSaida" Margin="0,12,0,0">
                                    <ComboBox x:Name="CmbMotorista"
                                              DisplayMemberPath="Display"
                                              SelectedValuePath="Matricula"
                                              materialDesign:HintAssist.Hint="Motorista"/>
                                </StackPanel>

                                <!-- Retorno -->
                                <StackPanel x:Name="PanelRetorno" Margin="0,12,0,0" Visibility="Collapsed">
                                    <TextBox x:Name="TxtHodometroRetorno"
                                             materialDesign:HintAssist.Hint="Hodômetro (chegada)"
                                             Margin="0,0,0,10"/>
                                    <TextBox x:Name="TxtRedsRetorno"
                                             materialDesign:HintAssist.Hint="Número REDS"/>
                                </StackPanel>

                                <Button x:Name="BtnLancamento"
                                        Content="Executar lançamento"
                                        Margin="0,14,0,0"
                                        Padding="16,10"
                                        MinHeight="44"
                                        VerticalContentAlignment="Center"
                                        Style="{StaticResource MaterialDesignFlatMidBgButton}"
                                        Click="BtnLancamento_Click"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                </TabControl>
            </Grid>
        </materialDesign:Card>

        <!-- SPLITTER -->
        <GridSplitter Grid.Row="3"
                      Height="6"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Background="#22000000"/>

        <!-- LOG -->
        <Grid Grid.Row="4" Margin="20,0,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,8">
                <TextBlock Text="Log" FontWeight="SemiBold" FontSize="14" DockPanel.Dock="Left"/>
            </DockPanel>

            <materialDesign:Card Grid.Row="1" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <ProgressBar x:Name="BusyBar"
                                 Height="4"
                                 IsIndeterminate="True"
                                 Visibility="Collapsed"/>

                    <TextBox x:Name="TxtLog"
                             Grid.Row="1"
                             FontFamily="Cascadia Mono"
                             FontSize="14"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Padding="12"
                             Background="{DynamicResource MaterialDesignPaper}"/>
                </Grid>
            </materialDesign:Card>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="5" Background="#0A000000" Padding="12,8">
            <DockPanel>
                <TextBlock x:Name="TxtStatus" Text="Pronto." Opacity="0.8" DockPanel.Dock="Left"/>
                <TextBlock x:Name="TxtBuild" Text="WPF (.NET 8)" Opacity="0.6" DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
